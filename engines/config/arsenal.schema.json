{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://transparenciabr.org/schemas/arsenal.schema.json",
  "title": "TransparenciaBR Arsenal API Catalog",
  "type": "object",
  "required": ["version", "updated_at", "defaults", "apis"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "updated_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "defaults": {
      "type": "object",
      "additionalProperties": true,
      "required": ["rate_limit", "retry", "timeout_ms", "user_agent"],
      "properties": {
        "rate_limit": {
          "type": "object",
          "required": ["rpm", "rph", "concurrent"],
          "properties": {
            "rpm": { "type": "integer", "minimum": 1 },
            "rph": { "type": "integer", "minimum": 1 },
            "concurrent": { "type": "integer", "minimum": 1 }
          }
        },
        "retry": {
          "type": "object",
          "required": ["max_attempts", "base_ms", "max_ms"],
          "properties": {
            "max_attempts": { "type": "integer", "minimum": 1 },
            "base_ms": { "type": "integer", "minimum": 1 },
            "max_ms": { "type": "integer", "minimum": 1 }
          }
        },
        "timeout_ms": { "type": "integer", "minimum": 1000 },
        "user_agent": { "type": "string", "minLength": 8 }
      }
    },
    "apis": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/apiEntry" }
    }
  },
  "$defs": {
    "dominio": {
      "type": "string",
      "enum": [
        "legislativo",
        "controle_externo",
        "controle_interno",
        "compras",
        "orcamento",
        "eleicoes",
        "cadastros",
        "diarios",
        "geo",
        "saude",
        "educacao",
        "saneamento",
        "social",
        "ambiente",
        "economia",
        "internacional",
        "noticias"
      ]
    },
    "prioridade": {
      "type": "string",
      "enum": ["imediata", "sprint_2", "sprint_3", "futuro"]
    },
    "method": {
      "type": "string",
      "enum": ["GET", "POST"]
    },
    "format": {
      "type": "string",
      "enum": ["json", "csv", "xml", "zip_csv", "ftp_dbc", "ndjson"]
    },
    "authType": {
      "type": "string",
      "enum": ["none", "api_key_query", "api_key_header", "bearer", "certificate", "inlabs_login"]
    },
    "paginationType": {
      "type": "string",
      "enum": [
        "none",
        "offset",
        "page",
        "cursor",
        "link_header",
        "date_window",
        "iter_ids",
        "year_loop",
        "year_zip",
        "bulk_download",
        "uf_loop",
        "bigquery_query",
        "ftp_dbc",
        "catalog_scrape",
        "inlabs_daily"
      ]
    },
    "auth": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": { "$ref": "#/$defs/authType" },
        "env_var": { "type": "string" },
        "header": { "type": "string" },
        "query_param": { "type": "string" },
        "login_url": { "type": "string" },
        "secret_name": { "type": "string" }
      }
    },
    "pagination": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": { "$ref": "#/$defs/paginationType" },
        "limit_param": { "type": "string" },
        "offset_param": { "type": "string" },
        "page_param": { "type": "string" },
        "per_page_param": { "type": "string" },
        "start_page": { "type": "integer" },
        "cursor_param": { "type": "string" },
        "cursor_field": { "type": "string" },
        "start_param": { "type": "string" },
        "end_param": { "type": "string" },
        "window_days": { "type": "integer" },
        "lookback_days": { "type": "integer" },
        "id_source": { "type": "string" },
        "start_year": { "type": "integer" },
        "end_year": { "type": "integer" },
        "index_url": { "type": "string" },
        "pattern": { "type": "string" },
        "lookback_months": { "type": "integer" },
        "daily_path": { "type": "string" },
        "dataset": { "type": "string" },
        "query": { "type": "string" },
        "total_field": { "type": "string" },
        "page_size": { "type": "integer" }
      }
    },
    "rate_limit": {
      "type": "object",
      "required": ["rpm", "rph", "concurrent"],
      "properties": {
        "rpm": { "type": "integer", "minimum": 1 },
        "rph": { "type": "integer", "minimum": 1 },
        "concurrent": { "type": "integer", "minimum": 1 }
      }
    },
    "incremental": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["field", "type"],
          "properties": {
            "field": { "type": "string" },
            "type": { "type": "string", "enum": ["date", "cursor"] },
            "initial": { "type": "string" }
          }
        }
      ]
    },
    "bigquery": {
      "type": "object",
      "required": ["external_table_name", "schema_inferable"],
      "properties": {
        "external_table_name": { "type": "string", "minLength": 1 },
        "schema_inferable": { "type": "boolean" }
      }
    },
    "apiEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "dominio",
        "fonte",
        "base_url",
        "endpoint",
        "method",
        "auth",
        "pagination",
        "format",
        "rate_limit",
        "incremental",
        "gcs_prefix",
        "bigquery",
        "prioridade"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "dominio": { "$ref": "#/$defs/dominio" },
        "fonte": { "type": "string", "minLength": 1 },
        "base_url": { "type": "string", "minLength": 4 },
        "endpoint": { "type": "string" },
        "method": { "$ref": "#/$defs/method" },
        "auth": { "$ref": "#/$defs/auth" },
        "pagination": { "$ref": "#/$defs/pagination" },
        "format": { "$ref": "#/$defs/format" },
        "rate_limit": { "$ref": "#/$defs/rate_limit" },
        "incremental": { "$ref": "#/$defs/incremental" },
        "gcs_prefix": {
          "type": "string",
          "pattern": "^[a-z0-9_/\\-]+$"
        },
        "bigquery": { "$ref": "#/$defs/bigquery" },
        "prioridade": { "$ref": "#/$defs/prioridade" },
        "notes": { "type": "string" }
      }
    }
  }
}
