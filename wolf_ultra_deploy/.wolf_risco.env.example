# WOLF ULTRA — blindagens de risco (exemplo)
# Copie para  /opt/wolf/repo/.wolf_risco.env  (ou /opt/wolf/.wolf_risco.env)
# e rode  bash wolf_ultra_deploy/install.sh  para aplicar.
# SEM este arquivo, valem os DEFAULTS do codigo (mostrados abaixo).
#
# Aprendidas com 05/07 (Bra-Nor / Mex-Eng): churning fatal no empate morto,
# sem trava de lucro (chegou a +4,17 e devolveu tudo), momentum sensivel demais.

# Momentum: variacao minima do mid p/ disparar ordem. 0.02 = 2% (era 0.0008 = churning)
WOLF_TRIGGER_PCT=0.02
# Recolhe posicoes a partir deste minuto do jogo (relogio ESPN)
WOLF_FLATTEN_MIN=80
# Cooldown por token: 1 ordem a cada N segundos (anti-churning)
WOLF_COOLDOWN_S=45
# STOP-LOSS por jogo (US$): se P/L <= isto, recolhe e para
WOLF_STOP_LOSS_USD=-5.0
# TAKE-PROFIT por jogo (US$): se P/L >= isto, trava lucro e para
WOLF_TAKE_PROFIT_USD=6.0
# TRAILING (US$): se recuar isto do pico de lucro (pico>=1.5), trava e para
WOLF_TRAIL_GIVEBACK_USD=2.5
# Faixa de preco "viva" — so opera mercados entre MIN e MAX (evita empate morto)
WOLF_MIN_PRICE=0.12
WOLF_MAX_PRICE=0.90
# Teto de exposicao acumulada por jogo (US$)
WOLF_MAX_STAKE_GAME_USD=1000.0
# Intervalo do loop (segundos)
WOLF_POLL_S=3.0
