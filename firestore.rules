rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /** Débito fixo Laboratório Oráculo (créditos) — alinhar ao produto */
    function oracleLaboratorioCost() {
      return 200;
    }

    function isNumericLike(v) {
      return v is int || v is float;
    }

    /**
     * Validação no servidor do débito: delta exatamente igual ao custo do laboratório,
     * saldo não negativo. O cliente não pode escolher valores arbitrários no console.
     */
    function isValidCreditDeduction() {
      let prev = resource.data.creditos;
      let next = request.resource.data.creditos;
      let delta = prev - next;
      return isNumericLike(prev)
        && isNumericLike(next)
        && next >= 0
        && delta == oracleLaboratorioCost()
        && prev >= delta;
    }

    /** Cota freemium diária — 300 créditos não-cumulativos. */
    function dailyFreemiumQuota() {
      return 300;
    }

    /**
     * Reset diário: o cliente pode "recarregar" o saldo para 300 desde que
     * mude também `last_login_date` para um string diferente. Isto evita que
     * um cliente recupere 300 créditos enquanto mantém a mesma data.
     */
    function isValidDailyReset() {
      let next = request.resource.data.creditos;
      let nextDate = request.resource.data.last_login_date;
      let prevDate = resource.data.keys().hasAny(['last_login_date'])
        ? resource.data.last_login_date
        : '';
      return isNumericLike(next)
        && next == dailyFreemiumQuota()
        && nextDate is string
        && nextDate.size() >= 8
        && nextDate != prevDate;
    }

    /** Tier do utilizador (custom claim definido pela function `grantRole`). */
    function userTier() {
      return request.auth != null && request.auth.token.tier is string
        ? request.auth.token.tier
        : 'free';
    }

    /** Premium ou superior (god_mode também passa). */
    function isPremium() {
      return userTier() == 'premium' || userTier() == 'god_mode';
    }

    /** God-mode (apenas claim explícita; nunca por e-mail hardcoded). */
    function isGodMode() {
      return userTier() == 'god_mode';
    }

    match /usuarios/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      /**
       * Perfil inicial: o cliente NUNCA pode marcar a si mesmo como
       * admin / role=admin / creditos_ilimitados / saldo > cota diária.
       * O perfil GOD do Líder Supremo é injetado pela Cloud Function
       * (Admin SDK) — nunca pelo SDK web. Aqui só permitimos os campos
       * neutros do onboarding freemium.
       */
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly([
          'email', 'creditos', 'creditos_ilimitados', 'isAdmin', 'role',
          'last_login_date', 'updated_at'
        ])
        && request.resource.data.creditos is int
        && request.resource.data.creditos >= 0
        && request.resource.data.creditos <= dailyFreemiumQuota()
        && request.resource.data.creditos_ilimitados == false
        && request.resource.data.isAdmin == false
        && request.resource.data.role == 'user'
        && request.resource.data.last_login_date is string;

      /**
       * Update tem dois caminhos legítimos do cliente:
       *   1. Débito do Oráculo Laboratório (`isValidCreditDeduction`).
       *   2. Reset diário freemium (`isValidDailyReset`).
       * Em ambos NÃO pode haver mudança de `isAdmin`, `role`,
       * `creditos_ilimitados` ou `email` (anti-escalonamento).
       * Esses campos só podem ser tocados pelo Admin SDK / Cloud
       * Function `grantRole`.
       */
      allow update: if request.auth != null
        && request.auth.uid == userId
        && (
          (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['creditos', 'updated_at'])
            && resource.data.keys().hasAny(['creditos'])
            && isValidCreditDeduction()
          ) ||
          (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['creditos', 'last_login_date', 'updated_at'])
            && isValidDailyReset()
          )
        )
        // Anti-escalonamento: nenhum dos campos privilegiados pode mudar.
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['isAdmin', 'role', 'creditos_ilimitados', 'email']);

      allow delete: if false;
    }

    match /politicos/{pid} {
      allow read: if true;
      allow write: if false;
    }

    match /alertas_bodes/{aid} {
      allow read: if true;
      allow write: if false;
    }

    match /transparency_reports/{reportId} {
      allow get: if true;
      allow list: if request.query.limit != null
        && request.query.limit <= 50;
      allow write: if false;
    }

    /** QG Advocacia / BI comercial — apenas o uid proprietário (admin), documentos privados */
    match /radar_dossiers/{rid} {
      allow read: if request.auth != null
        && resource.data.uid_proprietario == request.auth.uid
        && resource.data.is_private == true;
      allow write: if false;
    }

    match /radar_comercial/{cid} {
      allow read: if request.auth != null
        && resource.data.uid_proprietario == request.auth.uid
        && resource.data.is_private == true;
      allow write: if false;
    }

    /**
     * Dossiês factuais gerados pela engine 26. Leitura liberada para tier
     * premium/god_mode. Escrita apenas via Admin SDK (engines / Cloud
     * Functions com privilégio).
     */
    match /dossies_factuais/{did} {
      allow read: if request.auth != null && isPremium();
      allow write: if false;
    }

    /** Auditoria de alterações de papel — somente god_mode pode ler. */
    match /audit_role_changes/{aid} {
      allow read: if request.auth != null && isGodMode();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
