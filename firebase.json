{
  "hosting": {
    "public": "frontend/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/datalake/universe-roster",
        "function": {
          "functionId": "getUniverseRoster",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/api/sprint/status",
        "function": {
          "functionId": "getSprintStatus",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/api/datalake/dashboard-kpis",
        "function": {
          "functionId": "getDashboardKPIs",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/api/datalake/alvos",
        "function": {
          "functionId": "getAlvos",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/api/datalake/dossie-ceap",
        "function": {
          "functionId": "getDossieCeapKPIs",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/api/vertex/ask",
        "function": {
          "functionId": "askVertexAgent",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/api/datalake/emendas-kpis",
        "function": {
          "functionId": "getEmendasKPIs",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/api/datalake/patrimonio-kpis",
        "function": {
          "functionId": "getPatrimonioKPIs",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/api/datalake/viagens-kpis",
        "function": {
          "functionId": "getViagensKPIs",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/api/datalake/gabinete-kpis",
        "function": {
          "functionId": "getNepotismoKPIs",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/api/datalake/nepotismo-kpis",
        "function": {
          "functionId": "getNepotismoKPIs",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/api/datalake/nepotismo-cruzado-kpis",
        "function": {
          "functionId": "getNepotismoCruzadoKPIs",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/api/datalake/empresas-prefeituras-kpis",
        "function": {
          "functionId": "getEmpresasPrefeiturasKPIs",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/api/datalake/anomalias-kpis",
        "function": {
          "functionId": "getAnomaliasKPIs",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/api/datalake/risco-kpis",
        "function": {
          "functionId": "getRiscoKPIs",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/api/datalake/politico-despesas",
        "function": {
          "functionId": "getPoliticoDespesas",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/api/datalake/dossie-aurora",
        "function": {
          "functionId": "getDossieAurora",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/sprint",
        "destination": "/sprint.html"
      },
      {
        "source": "/sala-de-guerra/**",
        "destination": "/sala-de-guerra/index.html"
      },
      {
        "source": "/api/consent",
        "function": {
          "functionId": "enrichment",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/enrichment",
        "function": {
          "functionId": "enrichment",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/datalake/sacanagens",
        "function": {
          "functionId": "getSacanagens",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "/sala-de-guerra/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-store, no-cache, must-revalidate, max-age=0"
          }
        ]
      },
      {
        "source": "**",
        "headers": [
          {
            "key": "Strict-Transport-Security",
            "value": "max-age=31536000; includeSubDomains; preload"
          },
          {
            "key": "X-Frame-Options",
            "value": "SAMEORIGIN"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "Permissions-Policy",
            "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()"
          },
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; script-src 'self' 'unsafe-eval' https://apis.google.com https://www.gstatic.com https://www.google.com https://www.gstatic.com/firebasejs; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https: blob:; connect-src 'self' https://*.googleapis.com https://storage.googleapis.com https://*.gstatic.com https://*.firebaseio.com https://*.firebasedatabase.app wss://*.firebaseio.com wss://*.firebasedatabase.app https://identitytoolkit.googleapis.com https://securetoken.googleapis.com https://www.googleapis.com https://firebasestorage.googleapis.com https://*.cloudfunctions.net https://firebase.googleapis.com https://firestore.googleapis.com https://dadosabertos.camara.leg.br https://legis.senado.leg.br https://apis.codante.io https://pncp.gov.br https://brasilapi.com.br https://servicodados.ibge.gov.br https://*.transparenciabr.com.br https:; frame-src 'self' https://accounts.google.com https://*.firebaseapp.com https://*.google.com; worker-src 'self' blob:; manifest-src 'self'"
          }
        ]
      },
      {
        "source": "/index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, must-revalidate"
          }
        ]
      },
      {
        "source": "**/*.woff2",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/robots.txt",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          },
          {
            "key": "Content-Type",
            "value": "text/plain; charset=utf-8"
          }
        ]
      },
      {
        "source": "/sitemap.xml",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          },
          {
            "key": "Content-Type",
            "value": "application/xml; charset=utf-8"
          }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    },
    {
      "source": "functions-telegram",
      "codebase": "telegram-bot",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local",
        "test",
        "sql",
        "*.md"
      ],
      "runtime": "nodejs20"
    }
  ]
}
