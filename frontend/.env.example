# Ver também `../.env.example` na raiz do repositório (variáveis backend + secrets comentados).
#
# Firebase (obrigatório para dados em tempo real)
# O projectId deve coincidir com o projeto GCP/Firestore (predefinição: transparenciabr).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=transparenciabr
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Créditos — documento Firestore em usuarios/{uid} (bootstrap anónimo)
VITE_INITIAL_USER_CREDITS=320

# Painel privado /radar/dossiers — UID Firebase Auth do operador (Google Sign-In)
VITE_RADAR_ADMIN_UID=

# Stripe — fallback quando Cloud Functions não estão deployadas (Payment Link ou checkout de teste)
# VITE_STRIPE_PAYMENT_LINK_URL=https://buy.stripe.com/test_...

# Mapa municipal — URL pública do ficheiro .pmtiles (malha IBGE)
# Ex.: https://storage.googleapis.com/seu-bucket/br-municipios.pmtiles
VITE_BR_PM_TILES_URL=
VITE_PM_TILES_SOURCE_LAYER=municipios
